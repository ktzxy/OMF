#===============================================================================
# OMF 配置文件模板 (脱敏)
# 用法: cp conf/omf.conf.example conf/omf.conf && 按需修改
# 修改后执行: omf config validate
# 注意: 真实密码建议通过环境变量注入, 例如 export ORACLE_PASSWORD=xxx
#===============================================================================

# ===== 数据库配置 =====
ORACLE_USER="oracle"
ORACLE_GROUP="oinstall"
ORACLE_BASE="/u01/app/oracle"
# ORACLE_HOME 留空则按 ORACLE_VERSION 自动推导 (19 -> /u01/app/oracle/product/19.3.0/dbhome_1)
# 如需自定义安装路径, 显式指定即可覆盖:
# ORACLE_HOME="/u01/app/oracle/product/19.3.0/dbhome_1"
ORACLE_HOME=""
# Oracle 主版本 (仅支持 CDB 系列: 18 / 19 / 21 / 23); 用于推导默认安装包名与 CVU 兼容假名
ORACLE_VERSION="19"
# 安装包 zip 路径 (留空则按 ORACLE_VERSION 推导默认名, 如 LINUX.X64_193000_db_home.zip)
ORACLE_ZIP=""
ORACLE_SID="ARTERY"
PDB_NAME="ARTERYPDB"
# 监听器端口 (默认 1521); 用 omf listener port <新端口> 修改会同步写回此处
LISTENER_PORT="1521"

# ===== 内存规划 (用于 SGA / HugePages 估算) =====
# Oracle 内存占物理内存百分比 (默认 80)
ORACLE_MEM_RATIO="80"
# SGA 占 Oracle 内存百分比 (默认 75)
SGA_RATIO="75"
# 预留大页后至少给 OS 保留的空闲内存(MB), 防止小内存机器被大页吃满 (默认 2048)
HUGEPAGES_RESERVE_FREE_MB="2048"
# 是否将大页预留推迟到 omf db create 之前 (true/false)
#   true:  env prepare 不立即预留大页(释放内存给安装器), 建库前再预留
#   false: env prepare 立即预留大页(传统行为)
HUGEPAGES_DEFER="false"

# ===== 密码配置 (请替换为真实值, 或改用环境变量注入) =====
ORACLE_PASSWORD="${ORACLE_PASSWORD:-ChangeMe_123}"
SYSTEM_PASSWORD="${SYSTEM_PASSWORD:-ChangeMe_123}"
PDB_PASSWORD="${PDB_PASSWORD:-ChangeMe_123}"
APP_USER="dherp"
APP_PASSWORD="${APP_PASSWORD:-ChangeMe_123}"

# ===== 存储路径 =====
ORACLE_DATA_BASE="/data/oracle"
ORACLE_DATA="/data/oracle/oradata"
ORACLE_ARCH="/data/oracle/archivelog"
ORACLE_FRA="/data/oracle/fast_recovery"
ORACLE_BACKUP="/backup/oracle"

# ===== 数据库参数 =====
CHARSET="AL32UTF8"
NLS_LANG="AMERICAN_AMERICA.AL32UTF8"
PROCESSES="1500"
OPEN_CURSORS="1000"
REDO_SIZE_MB="2048"
# FRA (快速恢复区) 大小(MB). 注意: 若配置值超过 FRA 所在磁盘的可用空间,
# omf db create 会自动下调到"可用空间 - 15GB(预留给数据文件+归档)"并告警, 避免 DBCA 报 DBT-06604 建库失败.
# 生产环境建议将 /data/oracle 单独挂载到足够大的磁盘, 使此处 40GB 能真实生效.
FRA_SIZE_MB="40960"
FRA_SIZE_MB_MIN="20480"

# ===== Data Guard =====
ENABLE_DG="false"
PRIMARY_IP="192.168.0.108"
STANDBY_IP="192.168.0.110"
STANDBY_SID="${STANDBY_SID:-ARTERY}"

# ===== 备份策略 =====
BACKUP_MODE="both"
BACKUP_RETENTION_DAYS="30"
# 即将过期高亮阈值(天): 留空则按保留期的 1/5 自动计算(钳制 2~7 天); 设置后固定按该值
BACKUP_WARN_DAYS=""
BACKUP_COMPRESSION="ALL"
BACKUP_PARALLEL="4"

# ===== 框架自更新 =====
OMF_UPDATE_URL="${OMF_UPDATE_URL:-}"
# 可选: 压缩包 sha256 (用于 self-update 完整性校验, 留空则不校验)
OMF_UPDATE_SHA256="${OMF_UPDATE_SHA256:-}"

# ===== 清理策略 =====
LOG_RETENTION_DAYS="7"
AUDIT_RETENTION_DAYS="30"
TRACE_RETENTION_DAYS="7"
